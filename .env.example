# 智能点菜系统 - 环境变量模板
# 复制为 .env.production 后填入实际值

# PocketBase API 地址（默认通过 Nginx 反向代理）
VITE_PB_URL=/api

# Sentry DSN（前端错误监控）
# 获取方式：在 sentry.io 创建项目后，复制 DSN 链接
# 示例：VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# 未配置时 Sentry 自动禁用，不影响应用运行
VITE_SENTRY_DSN=

# 应用版本号（用于 Sentry Release 追踪）
VITE_APP_VERSION=1.0.2
